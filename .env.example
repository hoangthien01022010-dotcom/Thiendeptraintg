# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# Next.js
NEXT_PUBLIC_APP_NAME=AI All-in-One Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI APIs
NEXT_PUBLIC_OPENAI_API_KEY=your_openai_key
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_key
NEXT_PUBLIC_CLAUDE_API_KEY=your_claude_key
NEXT_PUBLIC_DEEPSEEK_API_KEY=your_deepseek_key

# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT & Authentication
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=7d

# AI APIs
OPENAI_API_KEY=your_openai_key
OPENAI_ORG_ID=your_org_id

GEMINI_API_KEY=your_gemini_key

CLAUDE_API_KEY=your_claude_key

DEEPSEEK_API_KEY=your_deepseek_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aiplatform
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aiplatform
DB_USER=postgres
DB_PASSWORD=postgres

# Storage
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-platform-bucket

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@aiplatform.com

# Payment Gateway
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# Redis (Optional - for caching/sessions)
REDIS_URL=redis://localhost:6379

# Socket.io
SOCKET_IO_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload
MAX_FILE_SIZE=52428800  # 50MB
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,jpg,jpeg,png,gif

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# ============================================
# DATABASE VARIABLES (Docker Compose)
# ============================================

POSTGRES_DB=aiplatform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432